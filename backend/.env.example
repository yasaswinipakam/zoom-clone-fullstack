# Zoom Clone Backend — Environment Variables
# Copy this file to `.env` and fill in real values for local development.
# These variables are not yet consumed by any code in Sprint 1 (no config.py
# exists yet); they are declared here so the expected shape of configuration
# is documented from project initialization onward, per the Engineering
# Design Document.

# --- Application ---
APP_ENV=development

# --- Database (SQLite for this assignment) ---
DATABASE_URL=sqlite:///./zoom_clone.db

# --- CORS: allowed frontend origins (comma-separated) ---
CORS_ORIGINS=http://localhost:3000
