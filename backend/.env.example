# Copy this file to .env and adjust values for your local environment.
# .env is git-ignored; this file (.env.example) is committed with
# placeholder/default values only, per Constitution Section 13.2.

APP_NAME="Zoom Clone API"
APP_VERSION=0.1.0
ENVIRONMENT=local

# Settings.debug defaults to false (safe default for accidentally-unset
# production environments). Uncomment to enable verbose/dev behavior
# locally:
# DEBUG=true

# SQLAlchemy connection string. Swapping to PostgreSQL later only
# requires changing this value (Constitution Section 13.3). The `data/`
# directory is created automatically if missing (see app/db/engine.py).
DATABASE_URL=sqlite:///./data/zoom_clone.db

# Comma-separated list is not used here — Pydantic parses a JSON-style
# list. For a single origin during local dev:
CORS_ALLOW_ORIGINS=["http://localhost:3000", "http://127.0.0.1:3000"]

LOG_LEVEL=INFO

# Authentication is optional; the frontend retains its default-user flow when disabled.
AUTH_ENABLED=true
JWT_SECRET_KEY="replace-with-a-long-random-secret-before-deployment"
